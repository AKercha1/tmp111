    "messages": [
      {
        "role": "user",
        "content": [
          {
            "text": "\u0447\u0442\u043E \u0432 \u0440\u0430\u0441\u0441\u043A\u0430\u0437\u0435?",
            "type": "text"
          },
          {
            "text": "\u003Cattachment name=\u0022\u0435\u0436\u0438\u043A\u0022\u003E\n# \uD83E\uDD94 \u0420\u0430\u0441\u0441\u043A\u0430\u0437 \u043F\u0440\u043E \u0451\u0436\u0438\u043A\u0430 \u0428\u0443\u0440\u0448\u0438\u043A\u0430\r\n\r\n\u0416\u0438\u043B-\u0431\u044B\u043B \u0451\u0436\u0438\u043A \u043F\u043E \u0438\u043C\u0435\u043D\u0438 **\u0428\u0443\u0440\u0448\u0438\u043A**. \u041E\u043D \u0431\u044B\u043B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439, \u043A\u043E\u043B\u044E\u0447\u0438\u0439 \u0438 \u043E\u0447\u0435\u043D\u044C \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0439 \u2014 \u043D\u0430\u0441\u0442\u043E\u043B\u044C\u043A\u043E, \u0447\u0442\u043E \u0434\u0430\u0436\u0435 \u0440\u043E\u0441\u0443 \u043D\u0430 \u0442\u0440\u0430\u0432\u0435 \u0441\u0447\u0438\u0442\u0430\u043B \u00AB\u0443\u0442\u0440\u0435\u043D\u043D\u0438\u043C\u0438 \u0434\u0435\u043B\u0430\u043C\u0438 \u043F\u0440\u0438\u0440\u043E\u0434\u044B\u00BB \u0438 \u043A\u0438\u0432\u0430\u043B \u0435\u0439, \u043A\u0430\u043A \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0439.\r\n\r\n\u041A\u0430\u0436\u0434\u044B\u0439 \u0432\u0435\u0447\u0435\u0440 \u0428\u0443\u0440\u0448\u0438\u043A \u0432\u044B\u0445\u043E\u0434\u0438\u043B \u043D\u0430 \u043F\u043E\u043B\u044F\u043D\u0443 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0442\u044C \u043B\u0435\u0441: \u0432\u0441\u0451 \u043B\u0438 \u043D\u0430 \u043C\u0435\u0441\u0442\u0435, \u043D\u0435 \u0437\u0430\u0431\u043B\u0443\u0434\u0438\u043B\u0430\u0441\u044C \u043B\u0438 \u0442\u0440\u043E\u043F\u0438\u043D\u043A\u0430, \u043D\u0435 \u0443\u043F\u0430\u043B\u0430 \u043B\u0438 \u0433\u0434\u0435-\u043D\u0438\u0431\u0443\u0434\u044C \u0437\u0432\u0435\u0437\u0434\u0430. \u041E\u043D \u0448\u0451\u043B \u0442\u0438\u0445\u043E-\u0442\u0438\u0445\u043E, \u0447\u0442\u043E\u0431\u044B \u043D\u0438\u043A\u043E\u0433\u043E \u043D\u0435 \u0442\u0440\u0435\u0432\u043E\u0436\u0438\u0442\u044C, \u0430 \u0435\u0433\u043E \u043B\u0430\u043F\u043A\u0438 \u0434\u0435\u043B\u0430\u043B\u0438 \u0432 \u0441\u0443\u0445\u0438\u0445 \u043B\u0438\u0441\u0442\u044C\u044F\u0445 \u0437\u0432\u0443\u043A: *\u0448\u0443\u0440-\u0448\u0443\u0440*. \u041E\u0442 \u044D\u0442\u043E\u0433\u043E \u0437\u0432\u0443\u043A\u0430 \u0438 \u043F\u043E\u0448\u043B\u043E \u0438\u043C\u044F.\r\n\r\n---\r\n\r\n## \uD83C\uDF32 \u041D\u043E\u0447\u043D\u0430\u044F \u0442\u0440\u0435\u0432\u043E\u0433\u0430\r\n\r\n\u041E\u0434\u043D\u0430\u0436\u0434\u044B \u043D\u043E\u0447\u044C\u044E \u043B\u0435\u0441 \u0437\u0430\u0448\u0435\u043F\u0442\u0430\u043B\u0441\u044F \u0438\u043D\u0430\u0447\u0435. \u0412\u0435\u0442\u0435\u0440 \u043F\u0440\u0438\u043D\u0451\u0441 \u0442\u043E\u043D\u0435\u043D\u044C\u043A\u0438\u0439 \u043F\u043B\u0430\u0447 \u2014 \u043A\u0430\u043A \u0431\u0443\u0434\u0442\u043E \u043A\u0442\u043E-\u0442\u043E \u043F\u044B\u0442\u0430\u043B\u0441\u044F \u043F\u043E\u0437\u0432\u0430\u0442\u044C \u043D\u0430 \u043F\u043E\u043C\u043E\u0449\u044C \u0438 \u0441\u0440\u0430\u0437\u0443 \u043F\u0435\u0440\u0435\u0434\u0443\u043C\u0430\u043B.\r\n\r\n\u0428\u0443\u0440\u0448\u0438\u043A \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F, \u043F\u043E\u0434\u043D\u044F\u043B \u043D\u043E\u0441 \u0438 \u043F\u043E\u043D\u044E\u0445\u0430\u043B \u0442\u0435\u043C\u043D\u043E\u0442\u0443.\r\n\r\n\u003E \u2014 \u041B\u0435\u0441 \u043D\u0435 \u043F\u043B\u0430\u0447\u0435\u0442 \u043F\u0440\u043E\u0441\u0442\u043E \u0442\u0430\u043A, \u2014 \u0441\u043A\u0430\u0437\u0430\u043B \u043E\u043D \u0441\u0430\u043C\u043E\u043C\u0443 \u0441\u0435\u0431\u0435.\r\n\r\n\u0418 \u043F\u043E\u0448\u0451\u043B \u0442\u0443\u0434\u0430, \u0433\u0434\u0435 \u043F\u043B\u0430\u0447 \u0431\u044B\u043B \u0433\u0440\u043E\u043C\u0447\u0435.\r\n\r\n\u041F\u043E\u0434 \u0435\u043B\u043E\u0432\u044B\u043C\u0438 \u0432\u0435\u0442\u043A\u0430\u043C\u0438 \u043E\u043D \u043D\u0430\u0448\u0451\u043B \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439 \u0444\u043E\u043D\u0430\u0440\u0438\u043A. \u041D\u0435 \u0436\u0438\u0432\u043E\u0439, \u043A\u043E\u043D\u0435\u0447\u043D\u043E \u2014 \u0436\u0435\u043B\u0435\u0437\u043D\u044B\u0439. \u041E\u043D \u043B\u0435\u0436\u0430\u043B \u0431\u043E\u043A\u043E\u043C \u0432 \u043C\u0445\u0443 \u0438 \u043C\u0438\u0433\u0430\u043B: *\u0442\u0438\u043A\u2026 \u0442\u0438\u043A\u2026* \u0431\u0443\u0434\u0442\u043E \u0443\u0441\u0442\u0430\u0432\u0430\u043B \u0434\u0430\u0436\u0435 \u0441\u0432\u0435\u0442\u0438\u0442\u044C. \u0420\u044F\u0434\u043E\u043C \u0441\u0438\u0434\u0435\u043B \u0441\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A \u0438 \u0441\u0435\u0440\u0434\u0438\u0442\u043E \u0445\u043B\u043E\u043F\u0430\u043B \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0430\u043C\u0438.\r\n\r\n\u2014 \u042D\u0442\u043E \u0442\u044B \u043F\u043B\u0430\u043A\u0430\u043B? \u2014 \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0451\u0436\u0438\u043A.\r\n\r\n\u2014 \u042F \u043D\u0435 \u043F\u043B\u0430\u0447\u0443! \u2014 \u0444\u044B\u0440\u043A\u043D\u0443\u043B \u0441\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A. \u2014 \u042F\u2026 \u044F \u0432\u043E\u0437\u043C\u0443\u0449\u0430\u043B\u0441\u044F! \u042D\u0442\u043E\u0442 \u0444\u043E\u043D\u0430\u0440\u044C \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u0441\u044F, \u0430 \u0431\u0435\u0437 \u043D\u0435\u0433\u043E \u043B\u044E\u0434\u0438 \u0431\u0443\u0434\u0443\u0442 \u0445\u043E\u0434\u0438\u0442\u044C \u043F\u043E \u0442\u0440\u043E\u043F\u0438\u043D\u043A\u0435 \u0438 \u0441\u043F\u043E\u0442\u044B\u043A\u0430\u0442\u044C\u0441\u044F. \u0410 \u0435\u0441\u043B\u0438 \u0441\u043F\u043E\u0442\u043A\u043D\u0443\u0442\u0441\u044F, \u043C\u043E\u0433\u0443\u0442 \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442\u044C \u043D\u0430 \u0433\u0440\u0438\u0431, \u0430 \u0433\u0440\u0438\u0431 \u2014 \u044D\u0442\u043E \u0432\u043E\u043E\u0431\u0449\u0435-\u0442\u043E \u0447\u044C\u044F-\u0442\u043E \u043A\u0440\u044B\u0448\u0430.\r\n\r\n\u0428\u0443\u0440\u0448\u0438\u043A \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B \u043D\u0430 \u0444\u043E\u043D\u0430\u0440\u044C \u0432\u043D\u0438\u043C\u0430\u0442\u0435\u043B\u044C\u043D\u043E, \u043A\u0430\u043A \u0434\u043E\u043A\u0442\u043E\u0440. \u041F\u043E\u0442\u043E\u043C \u043E\u0441\u0442\u043E\u0440\u043E\u0436\u043D\u043E \u0442\u043E\u043B\u043A\u043D\u0443\u043B \u0435\u0433\u043E \u043D\u043E\u0441\u043E\u043C. \u0424\u043E\u043D\u0430\u0440\u044C \u0437\u0432\u044F\u043A\u043D\u0443\u043B \u0438 \u0441\u043D\u043E\u0432\u0430 \u043C\u0438\u0433\u043D\u0443\u043B \u2014 \u0443\u0436\u0435 \u044F\u0440\u0447\u0435.\r\n\r\n\u003E \u2014 \u0417\u043D\u0430\u0447\u0438\u0442, \u043E\u043D \u0436\u0438\u0432\u043E\u0439\u2026 \u043F\u043E\u0447\u0442\u0438. \u041D\u0430\u0434\u043E \u0432\u0435\u0440\u043D\u0443\u0442\u044C.\r\n\r\n---\r\n\r\n## \u2728 \u041F\u0443\u0442\u0435\u0448\u0435\u0441\u0442\u0432\u0438\u0435 \u0441\u043E \u0441\u0432\u0435\u0442\u043E\u043C\r\n\r\n\u2014 \u041A\u0443\u0434\u0430? \u2014 \u0441\u043F\u0440\u043E\u0441\u0438\u043B \u0441\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A.\r\n\r\n\u2014 \u0422\u0443\u0434\u0430, \u0433\u0434\u0435 \u043E\u043D \u0434\u043E\u043B\u0436\u0435\u043D \u0441\u0432\u0435\u0442\u0438\u0442\u044C, \u2014 \u043E\u0442\u0432\u0435\u0442\u0438\u043B \u0451\u0436\u0438\u043A. \u2014 \u041D\u0430 \u0442\u0440\u043E\u043F\u0438\u043D\u043A\u0443. \u041D\u043E \u0442\u0440\u043E\u043F\u0438\u043D\u043A\u0430 \u0434\u043B\u0438\u043D\u043D\u0430\u044F, \u0430 \u043D\u043E\u0447\u044C \u043A\u043E\u0440\u043E\u0442\u043A\u0430\u044F.\r\n\r\n\u2014 \u042F \u043C\u043E\u0433\u0443 \u0431\u044B\u0442\u044C \u0437\u0430\u043F\u0430\u0441\u043D\u044B\u043C \u0441\u0432\u0435\u0442\u043E\u043C! \u2014 \u0441\u043A\u0430\u0437\u0430\u043B \u0441\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A. \u2014 \u042F \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0439, \u043D\u043E \u0433\u043E\u0440\u0434\u044B\u0439!\r\n\r\n\u0418 \u043E\u043D\u0438 \u043F\u043E\u0448\u043B\u0438 \u0432\u043C\u0435\u0441\u0442\u0435. \u0428\u0443\u0440\u0448\u0438\u043A \u043A\u0430\u0442\u0438\u043B \u0444\u043E\u043D\u0430\u0440\u044C \u043F\u0435\u0440\u0435\u0434 \u0441\u043E\u0431\u043E\u0439, \u0438\u043D\u043E\u0433\u0434\u0430 \u043F\u043E\u0434\u043F\u0438\u0440\u0430\u044F \u0435\u0433\u043E \u043B\u0431\u043E\u043C, \u0447\u0442\u043E\u0431\u044B \u0442\u043E\u0442 \u043D\u0435 \u0441\u043A\u0430\u0442\u0438\u043B\u0441\u044F \u0432 \u043B\u0443\u0436\u0443. \u0421\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A \u043B\u0435\u0442\u0435\u043B \u0440\u044F\u0434\u043E\u043C \u0438 \u043E\u0441\u0432\u0435\u0449\u0430\u043B \u0434\u043E\u0440\u043E\u0433\u0443, \u043A\u0430\u043A \u0432\u0430\u0436\u043D\u044B\u0439 \u0441\u043E\u043F\u0440\u043E\u0432\u043E\u0436\u0434\u0430\u044E\u0449\u0438\u0439.\r\n\r\n---\r\n\r\n## \uD83E\uDD89 \u041C\u0443\u0434\u0440\u044B\u0439 \u0441\u043E\u0432\u0435\u0442\r\n\r\n\u041F\u043E \u043F\u0443\u0442\u0438 \u0438\u043C \u0432\u0441\u0442\u0440\u0435\u0442\u0438\u043B\u0430\u0441\u044C \u0421\u043E\u0432\u0430, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0434\u0435\u043B\u0430\u043B\u0430 \u0432\u0438\u0434, \u0447\u0442\u043E \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0432\u0438\u0434\u0438\u0442.\r\n\r\n\u2014 \u0414\u043E\u0431\u0440\u043E\u0439 \u043D\u043E\u0447\u0438, \u2014 \u0432\u0435\u0436\u043B\u0438\u0432\u043E \u0441\u043A\u0430\u0437\u0430\u043B \u0428\u0443\u0440\u0448\u0438\u043A.\r\n\r\n\u2014 \u0423\u0433\u0443, \u2014 \u043E\u0442\u043E\u0437\u0432\u0430\u043B\u0430\u0441\u044C \u0421\u043E\u0432\u0430 \u0438 \u043F\u043E\u0441\u043C\u043E\u0442\u0440\u0435\u043B\u0430 \u043D\u0430 \u0444\u043E\u043D\u0430\u0440\u044C. \u2014 \u0412\u0430\u0436\u043D\u044B\u0439 \u0433\u0440\u0443\u0437?\r\n\r\n\u2014 \u041E\u0447\u0435\u043D\u044C.\r\n\r\n\u2014 \u0422\u043E\u0433\u0434\u0430 \u0434\u0435\u0440\u0436\u0438\u0442\u0435\u0441\u044C \u043F\u0440\u0430\u0432\u0435\u0435. \u0422\u0430\u043C \u043A\u043E\u0440\u0435\u043D\u044C \u0445\u0438\u0442\u0440\u044B\u0439 \u2014 \u043E\u043D \u0432\u0441\u0435\u0433\u0434\u0430 \u043F\u044B\u0442\u0430\u0435\u0442\u0441\u044F \u043F\u043E\u0434\u0441\u0442\u0430\u0432\u0438\u0442\u044C \u043B\u0430\u043F\u0443.\r\n\r\n\u0418 \u043E\u043D\u0438 \u0434\u0435\u0440\u0436\u0430\u043B\u0438\u0441\u044C \u043F\u0440\u0430\u0432\u0435\u0435.\r\n\r\n---\r\n\r\n## \uD83D\uDC30 \u041D\u0435\u043C\u043D\u043E\u0433\u043E \u0441\u043C\u0435\u043B\u043E\u0441\u0442\u0438\r\n\r\n\u0412 \u0442\u0440\u0430\u0432\u0435 \u0437\u0430\u0432\u043E\u0437\u0438\u043B\u0430\u0441\u044C \u0422\u0435\u043D\u044C \u2014 \u044D\u0442\u043E \u043E\u043A\u0430\u0437\u0430\u043B\u0441\u044F \u0437\u0430\u0439\u0447\u043E\u043D\u043E\u043A, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0431\u043E\u044F\u043B\u0441\u044F \u0442\u0435\u043C\u043D\u043E\u0442\u044B \u0438 \u0441\u0442\u0435\u0441\u043D\u044F\u043B\u0441\u044F \u0432 \u044D\u0442\u043E\u043C \u043F\u0440\u0438\u0437\u043D\u0430\u0442\u044C\u0441\u044F.\r\n\r\n\u2014 \u042F \u043F\u0440\u043E\u0441\u0442\u043E\u2026 \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u044E, \u043A\u0430\u043A \u0448\u0443\u0440\u0448\u0438\u0442 \u0442\u0440\u0430\u0432\u0430, \u2014 \u0441\u043A\u0430\u0437\u0430\u043B \u043E\u043D \u0434\u0440\u043E\u0436\u0430\u0449\u0438\u043C \u0433\u043E\u043B\u043E\u0441\u043E\u043C.\r\n\r\n\u0421\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A \u043F\u043E\u0434\u043B\u0435\u0442\u0435\u043B \u0431\u043B\u0438\u0436\u0435 \u0438 \u0437\u0430\u0436\u0451\u0433\u0441\u044F \u044F\u0440\u0447\u0435.\r\n\r\n\u003E \u2014 \u041D\u0438\u0447\u0435\u0433\u043E \u0441\u0442\u0440\u0430\u0448\u043D\u043E\u0433\u043E. \u0422\u0435\u043C\u043D\u043E\u0442\u0430 \u043D\u0435 \u043A\u0443\u0441\u0430\u0435\u0442\u0441\u044F.\r\n\r\n\u0428\u0443\u0440\u0448\u0438\u043A \u043E\u0441\u0442\u0430\u043D\u043E\u0432\u0438\u043B\u0441\u044F.\r\n\r\n\u2014 \u0425\u043E\u0447\u0435\u0448\u044C \u0441 \u043D\u0430\u043C\u0438? \u041C\u044B \u043D\u0435\u0441\u0451\u043C \u0441\u0432\u0435\u0442. \u0421\u043E \u0441\u0432\u0435\u0442\u043E\u043C \u0432\u0441\u0435\u0433\u0434\u0430 \u043F\u0440\u043E\u0449\u0435 \u0438\u0434\u0442\u0438.\r\n\r\n\u0417\u0430\u0439\u0447\u043E\u043D\u043E\u043A \u043F\u043E\u0434\u0443\u043C\u0430\u043B \u0440\u043E\u0432\u043D\u043E \u0434\u0432\u0435 \u0441\u0435\u043A\u0443\u043D\u0434\u044B \u2014 \u044D\u0442\u043E \u043E\u0447\u0435\u043D\u044C \u0434\u043E\u043B\u0433\u043E \u0434\u043B\u044F \u0437\u0430\u0439\u0447\u043E\u043D\u043A\u0430 \u2014 \u0438 \u043A\u0438\u0432\u043D\u0443\u043B.\r\n\r\n---\r\n\r\n## \uD83D\uDD26 \u0421\u0432\u0435\u0442 \u043D\u0430 \u0441\u0432\u043E\u0451\u043C \u043C\u0435\u0441\u0442\u0435\r\n\r\n\u041D\u0430\u043A\u043E\u043D\u0435\u0446 \u043E\u043D\u0438 \u0434\u043E\u0431\u0440\u0430\u043B\u0438\u0441\u044C \u0434\u043E \u0442\u0440\u043E\u043F\u0438\u043D\u043A\u0438, \u043A\u043E\u0442\u043E\u0440\u0430\u044F \u0432\u0435\u043B\u0430 \u043A \u043E\u043F\u0443\u0448\u043A\u0435. \u041F\u043E\u0434 \u0434\u0435\u0440\u0435\u0432\u044F\u043D\u043D\u043E\u0439 \u0442\u0430\u0431\u043B\u0438\u0447\u043A\u043E\u0439 \u00AB\u041A \u0434\u043E\u043C\u0443\u00BB \u0441\u0442\u043E\u044F\u043B \u043A\u0430\u043C\u0435\u043D\u044C \u2014 \u0432\u0438\u0434\u043D\u043E, \u0441\u044E\u0434\u0430 \u0438 \u0441\u0442\u0430\u0432\u0438\u043B\u0438 \u0444\u043E\u043D\u0430\u0440\u044C.\r\n\r\n\u0428\u0443\u0440\u0448\u0438\u043A \u0443\u043F\u0451\u0440\u0441\u044F \u043B\u0430\u043F\u043A\u0430\u043C\u0438 \u0438 \u043F\u043E\u0434\u0442\u043E\u043B\u043A\u043D\u0443\u043B \u0444\u043E\u043D\u0430\u0440\u044C. \u0422\u043E\u0442 \u0432\u0441\u0442\u0430\u043B \u0440\u043E\u0432\u043D\u043E \u0438 \u0437\u0430\u0433\u043E\u0440\u0435\u043B\u0441\u044F \u0443\u0432\u0435\u0440\u0435\u043D\u043D\u043E, \u0442\u0451\u043F\u043B\u043E \u0438 \u0448\u0438\u0440\u043E\u043A\u043E. \u0422\u0440\u043E\u043F\u0438\u043D\u043A\u0430 \u0441\u0440\u0430\u0437\u0443 \u0441\u0442\u0430\u043B\u0430 \u043F\u043E\u0445\u043E\u0436\u0430 \u043D\u0430 \u0440\u0430\u0437\u0433\u043E\u0432\u043E\u0440: \u043F\u043E\u043D\u044F\u0442\u043D\u044B\u0439, \u0441\u043F\u043E\u043A\u043E\u0439\u043D\u044B\u0439, \u0432\u0435\u0434\u0443\u0449\u0438\u0439 \u0442\u0443\u0434\u0430, \u043A\u0443\u0434\u0430 \u043D\u0430\u0434\u043E.\r\n\r\n\u0421\u0432\u0435\u0442\u043B\u044F\u0447\u043E\u043A \u0440\u0430\u0441\u043F\u0440\u0430\u0432\u0438\u043B \u043A\u0440\u044B\u043B\u044B\u0448\u043A\u0438.\r\n\r\n\u2014 \u0422\u0435\u043F\u0435\u0440\u044C \u043D\u0438\u043A\u0442\u043E \u043D\u0435 \u043D\u0430\u0441\u0442\u0443\u043F\u0438\u0442 \u043D\u0430 \u0433\u0440\u0438\u0431\u044C\u044E \u043A\u0440\u044B\u0448\u0443.\r\n\r\n\u0417\u0430\u0439\u0447\u043E\u043D\u043E\u043A \u043F\u0440\u0438\u0449\u0443\u0440\u0438\u043B\u0441\u044F:\r\n\r\n\u2014 \u042F \u0434\u0443\u043C\u0430\u043B, \u043D\u043E\u0447\u044C \u2014 \u044D\u0442\u043E \u043A\u043E\u0433\u0434\u0430 \u0441\u0442\u0440\u0430\u0448\u043D\u043E. \u0410 \u043E\u043A\u0430\u0437\u0430\u043B\u043E\u0441\u044C \u2014 \u043D\u043E\u0447\u044C \u043F\u0440\u043E\u0441\u0442\u043E \u0436\u0434\u0451\u0442, \u0447\u0442\u043E\u0431\u044B \u043A\u0442\u043E-\u043D\u0438\u0431\u0443\u0434\u044C \u043F\u0440\u0438\u043D\u0451\u0441 \u0444\u043E\u043D\u0430\u0440\u044C.\r\n\r\n\u0428\u0443\u0440\u0448\u0438\u043A \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435 \u0441\u043A\u0430\u0437\u0430\u043B. \u041E\u043D \u0431\u044B\u043B \u0441\u0435\u0440\u044C\u0451\u0437\u043D\u044B\u0439. \u041D\u043E \u0432\u043D\u0443\u0442\u0440\u0438 \u0443 \u043D\u0435\u0433\u043E \u0441\u0442\u0430\u043B\u043E \u0442\u0430\u043A \u0442\u0438\u0445\u043E \u0438 \u0445\u043E\u0440\u043E\u0448\u043E, \u0431\u0443\u0434\u0442\u043E \u0432 \u043B\u0435\u0441\u0443 \u043F\u0440\u0438\u0431\u0440\u0430\u043B\u0438, \u0438 \u0432\u0441\u0451 \u0441\u043D\u043E\u0432\u0430 \u043D\u0430 \u043C\u0435\u0441\u0442\u0435.\r\n\r\n---\r\n\r\n## \uD83C\uDF05 \u0423\u0442\u0440\u043E\r\n\r\n\u041A\u043E\u0433\u0434\u0430 \u043E\u043D\u0438 \u0432\u043E\u0437\u0432\u0440\u0430\u0449\u0430\u043B\u0438\u0441\u044C \u043E\u0431\u0440\u0430\u0442\u043D\u043E, \u0432\u0435\u0442\u0435\u0440 \u0443\u0436\u0435 \u043D\u0435 \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u043B \u043F\u043B\u0430\u0447. \u041E\u043D \u043F\u0440\u0438\u043D\u043E\u0441\u0438\u043B \u0437\u0430\u043F\u0430\u0445 \u043C\u043E\u043A\u0440\u043E\u0439 \u0437\u0435\u043C\u043B\u0438, \u0448\u043E\u0440\u043E\u0445 \u043B\u0438\u0441\u0442\u044C\u0435\u0432 \u0438 \u043E\u0447\u0435\u043D\u044C \u0432\u0430\u0436\u043D\u043E\u0435 \u0447\u0443\u0432\u0441\u0442\u0432\u043E: \u0435\u0441\u043B\u0438 \u0447\u0442\u043E-\u0442\u043E \u043F\u043E\u0442\u0435\u0440\u044F\u043B\u043E\u0441\u044C \u2014 \u0435\u0433\u043E \u043C\u043E\u0436\u043D\u043E \u043D\u0430\u0439\u0442\u0438.\r\n\r\n\u041E\u0441\u043E\u0431\u0435\u043D\u043D\u043E \u0435\u0441\u043B\u0438 \u0442\u044B \u0451\u0436\u0438\u043A \u043F\u043E \u0438\u043C\u0435\u043D\u0438 **\u0428\u0443\u0440\u0448\u0438\u043A**,\r\n\u0443 \u0442\u0435\u0431\u044F \u043D\u043E\u0441, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0443\u043C\u0435\u0435\u0442 \u043D\u044E\u0445\u0430\u0442\u044C \u0437\u0430\u0431\u043E\u0442\u0443,\r\n\u0438 \u0434\u0440\u0443\u0437\u044C\u044F, \u043A\u043E\u0442\u043E\u0440\u044B\u0435 \u0443\u043C\u0435\u044E\u0442 \u0441\u0432\u0435\u0442\u0438\u0442\u044C, \u0434\u0430\u0436\u0435 \u043A\u043E\u0433\u0434\u0430 \u0441\u0430\u043C\u0438 \u043C\u0430\u043B\u0435\u043D\u044C\u043A\u0438\u0435.\r\n\r\n\u0410 \u043D\u0430\u0443\u0442\u0440\u043E \u0440\u043E\u0441\u0430 \u0441\u043D\u043E\u0432\u0430 \u043B\u0435\u0436\u0430\u043B\u0430 \u043D\u0430 \u0442\u0440\u0430\u0432\u0435.\r\n\u0428\u0443\u0440\u0448\u0438\u043A \u043A\u0438\u0432\u043D\u0443\u043B \u0435\u0439, \u043A\u0430\u043A \u0432\u0437\u0440\u043E\u0441\u043B\u044B\u0439, \u0438 \u043F\u043E\u0448\u0451\u043B \u043F\u0440\u043E\u0432\u0435\u0440\u044F\u0442\u044C \u043B\u0435\u0441 \u2014 \u0432\u0441\u0451 \u043B\u0438 \u043D\u0430 \u043C\u0435\u0441\u0442\u0435.\r\n\r\n\u003E \u041F\u043E\u0442\u043E\u043C\u0443 \u0447\u0442\u043E \u0438\u043D\u043E\u0433\u0434\u0430 \u0441\u0430\u043C\u043E\u0435 \u0433\u043B\u0430\u0432\u043D\u043E\u0435 \u0432 \u043B\u0435\u0441\u0443 \u2014 \u043D\u0435 \u043A\u043E\u043B\u044E\u0447\u043A\u0438,\r\n\u003E \u0430 \u043F\u0443\u0442\u044C, \u043A\u043E\u0442\u043E\u0440\u044B\u0439 \u0442\u044B \u043E\u0441\u0432\u0435\u0449\u0430\u0435\u0448\u044C \u0434\u043B\u044F \u0434\u0440\u0443\u0433\u0438\u0445. \uD83C\uDF1F\r\n\n\u003C/attachment\u003E",
            "type": "text"
          }
